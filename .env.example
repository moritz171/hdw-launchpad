# HDW Launchpad - Environment Configuration
# Kopiere diese Datei zu .env und fülle deine API-Keys ein

# Vercel Deployment Token (ERFORDERLICH)
# Erstelle einen Token unter: https://vercel.com/account/tokens
# Beispiel: vercel_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_TOKEN=

# Server Port
PORT=3001

# Node Environment
NODE_ENV=development

# GitHub User/Owner (optional, für GitHub Backup)
# Dein GitHub-Username (z.B. moritz171)
GITHUB_OWNER=

# User Email (für Git Commits)
USER_EMAIL=moritz@heavy-media.de
